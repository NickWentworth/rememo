generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./database.db"
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  password String
  verified Boolean @default(false)

  tasks   Task[]
  classes Class[]
}

model Task {
  id          String  @id @default(cuid())
  name        String  @default("Unnamed Task")
  class       String?
  description String?
  dueDate     String
  dueTime     String?
  progress    Int     @default(0)

  user   User   @relation(fields: [userId], references: [id])
  userId String
}

model Class {
  id    String @id @default(cuid())
  name  String
  color String

  user   User   @relation(fields: [userId], references: [id])
  userId String
}
