generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// TODO - add class data model
model User {
  id       String @id @default(cuid())
  username String
  tasks    Task[]
}

model Task {
  id          String  @id @default(cuid())
  name        String  @default("Unnamed Task")
  class       String?
  description String?
  dueDate     String
  dueTime     String?
  progress    Int     @default(0)

  user   User   @relation(fields: [userId], references: [id])
  userId String
}
